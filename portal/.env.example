# PostgreSQL on Oracle Cloud server
DATABASE_URL=postgresql://user:password@your-oracle-server:5432/marketing_mcp

# NextAuth
NEXTAUTH_URL=https://portal.statika.net
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Email provider for magic link auth (e.g., Resend, SendGrid)
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@statika.net

# Stripe (Phase 4)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# MCP Gateway URL
MCP_GATEWAY_URL=https://marketingmcp.statika.net

# Credential encryption key (same as MCP gateway)
CREDENTIAL_ENCRYPTION_KEY=your-64-char-hex-key
